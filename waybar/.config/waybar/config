{
    "layer": "top",
    "position": "top",
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 5,

    "modules-left": ["sway/workspaces", "custom/media"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "tray"],

    "sway/workspaces": {
        "all-outputs": true,
        "format": "{name}"
    },

    "custom/media": {
        "format": "󰝚 {}",
        "max-length": 35,
        "exec": "playerctl metadata --format '{{artist}} - {{title}}' --follow 2>/dev/null",
        "on-click": "playerctl play-pause"
    },

    "cpu": {
        "format": "󰍛 {usage}%",
        "tooltip": true,
        "interval": 2
    },

    "memory": {
        "format": "󰾆 {used}G",
        "tooltip": true,
        "tooltip-format": "Занято: {used}GiB\nДоступно: {avail}GiB"
    },

    "clock": {
        "format": "󰥔 {:%H:%M}",
        "tooltip": true,
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffeb'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        }
    },

    "tray": {
        "spacing": 10
    }
}
