#!/bin/bash
BLUE='\033[0;34m'
CYAN='\033[0;36m'
GOLD='\033[1;33m'
WHITE='\033[1;37m'
NC='\033[0m'

UPTIME=$(uptime -p | sed 's/up //')
RAM=$(free -h | awk '/Mem:/ { print $3 " / " $2 }')
CPU=$(grep 'cpu ' /proc/stat | awk '{usage=($2+$4)*100/($2+$4+$5)} END {printf "%.1f%%", usage}')
PACKAGES=$(pacman -Qn | wc -l)
AUR_PACKS=$(pacman -Qm | wc -l)

echo -e "${GOLD}в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ${NC}"
echo -e "${GOLD}в”Ӯ${NC}  ${WHITE}у°ЈҮ STATUS WINDOW: SYSTEM INFO${NC}            ${GOLD}в”Ӯ${NC}"
echo -e "${GOLD}в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө${NC}"
echo -e "${GOLD}в”Ӯ${NC}  ${CYAN}уұ‘Һ LEVEL (Uptime):${NC}  $UPTIME"
echo -e "${GOLD}в”Ӯ${NC}  ${CYAN}у°Қӣ MEMORY (Mana):${NC}   $RAM"
echo -e "${GOLD}в”Ӯ${NC}  ${CYAN}у°»  CPU LOAD:${NC}        $CPU"
echo -e "${GOLD}в”Ӯ${NC}  ${CYAN}у°Ҹ– PKGS (Native):${NC}   $PACKAGES"
echo -e "${GOLD}в”Ӯ${NC}  ${CYAN}у°®Ҝ AUR (Special):${NC}   $AUR_PACKS"
echo -e "${GOLD}в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө${NC}"
echo -e "${GOLD}в”Ӯ${NC}  ${WHITE}CLASS:${NC} ${BLUE}Arch Linux / Sway WM${NC}             ${GOLD}в”Ӯ${NC}"
echo -e "${GOLD}в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ${NC}"
