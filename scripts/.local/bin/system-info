#!/bin/bash
BLUE='\033[0;34m'
CYAN='\033[0;36m'
GOLD='\033[1;33m'
WHITE='\033[1;37m'
RED='\033[0;31m'
NC='\033[0m'

UPTIME=$(uptime -p | sed 's/up //')
RAM=$(free -h | awk '/Mem:/ { print $3 " / " $2 }')
CPU=$(grep 'cpu ' /proc/stat | awk '{usage=($2+$4)*100/($2+$4+$5)} END {printf "%.1f%%", usage}')
PACKAGES=$(pacman -Qn | wc -l)
AUR_PACKS=$(pacman -Qm | wc -l)

# Получаем температуру GPU
GPU_TEMP=$(nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits 2>/dev/null)
if [ -z "$GPU_TEMP" ]; then
    GPU_INFO="N/A"
else
    GPU_INFO="${GPU_TEMP}°C"
fi

echo -e "${GOLD}┌───────────────────────────────────────────┐${NC}"
echo -e "${GOLD}│${NC}  ${WHITE}󰣇 STATUS WINDOW: SYSTEM INFO${NC}            ${GOLD}│${NC}"
echo -e "${GOLD}├───────────────────────────────────────────┤${NC}"
echo -e "${GOLD}│${NC}  ${CYAN}󱑎 LEVEL (Uptime):${NC}  $UPTIME"
echo -e "${GOLD}│${NC}  ${CYAN}󰍛 MEMORY (Mana):${NC}   $RAM"
echo -e "${GOLD}│${NC}  ${CYAN}󰻠 CPU LOAD:${NC}        $CPU"
echo -e "${GOLD}│${NC}  ${RED}󰈸 GPU (Heat):${NC}       $GPU_INFO"
echo -e "${GOLD}│${NC}  ${CYAN}󰏖 PKGS (Native):${NC}   $PACKAGES"
echo -e "${GOLD}│${NC}  ${CYAN}󰮯 AUR (Special):${NC}   $AUR_PACKS"
echo -e "${GOLD}├───────────────────────────────────────────┤${NC}"
echo -e "${GOLD}│${NC}  ${WHITE}CLASS:${NC} ${BLUE}Arch Linux / Sway WM${NC}             ${GOLD}│${NC}"
echo -e "${GOLD}└───────────────────────────────────────────┘${NC}"
