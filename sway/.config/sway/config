# --- МЕНЮ ВЫХОДА ---
# Нажми Win + Shift + E для меню выключения
bindsym $mod+Shift+e exec wlogout -b 2


# Привязка к рабочим столам
assign [app_id="firefox"] workspace number 1
assign [app_id="foot"] workspace number 2
assign [app_id="yandex-music"] workspace number 3
assign [app_id="YandexMusic"] workspace number 3

# Авто-фокус на окно при запуске (опционально)
for_window [app_id="firefox"] focus

# Очищаем старые процессы и запускаем заново
exec_always pkill wl-paste
exec_always wl-paste --type text --watch cliphist store
exec_always wl-paste --type image --watch cliphist store

# Обновленный бинд (добавил очистку от пустых строк)
bindsym $mod+v exec cliphist list | rofi -dmenu -p "Clipboard" | cliphist decode | wl-copy

