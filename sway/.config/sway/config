# --- ПЕРЕМЕННЫЕ ---
set $mod Mod4

# --- ГРАФИЧЕСКИЙ ОКРУЖЕНИЕ (Фикс Flameshot и Тултипов) ---
exec dbus-update-activation-environment --all
exec systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP

# --- КЛАВИАТУРА ---
input * {
    xkb_layout us,ru
    xkb_options grp:win_space_toggle
}
# Win+Space ничего не делает в Sway, чтобы не мешать раскладке
bindsym $mod+space nop

# --- ТАЙЛИНГ (Тот самый переключатель) ---
# Нажми Win+T чтобы вернуть окно в плитку или сделать плавающим
bindsym $mod+t floating toggle

# --- СКРИНШОТЫ (Flameshot) ---
bindsym Print exec flameshot gui

# --- МУЛЬТИМЕДИА ---
# Управление звуком напрямую через Wireplumber (без уведомлений)
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute        exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle

# Управление музыкой (Яндекс Музыка, браузер и т.д.)
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous

# На всякий случай кнопки стоп и перемотки (если есть на клаве)
bindsym XF86AudioStop exec playerctl stop

# Яркость (если у тебя ноутбук или монитор поддерживает)
bindsym XF86MonBrightnessUp   exec lightctl up
bindsym XF86MonBrightnessDown exec lightctl down

# --- ГОРЯЧИЕ КЛАВИШИ ---
bindsym $mod+Return exec foot
bindsym $mod+q kill
bindsym $mod+r exec rofi -show drun
bindsym $mod+e exec nautilus
bindsym $mod+Shift+c reload
bindsym $mod+p exec ~/.local/bin/conf-edit
bindsym $mod+f exec bash -c 'sleep 0.1 && swaymsg "fullscreen toggle"'


# --- РАБОЧИЕ СТОЛЫ ---
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9

# --- СВОРАЧИВАНИЕ (Scratchpad) ---
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# Биндим блокировку на $mod+L
bindsym $mod+l exec ~/.local/bin/lockscreen

# Автоблокировка через swayidle (установи: sudo pacman -S swayidle)
# Через 10 минут (600 сек) заблокирует экран
exec swayidle -w \
     timeout 600 '~/.local/bin/lockscreen'

# --- АВТОЗАПУСК ---
#exec_always "killall waybar; waybar"
#exec_always swaybg -i ~/Pictures/Wallpapers/anime_wallpaper.jpg -m fill
#exec avizo-service

# --- ВНЕШНИЙ ВИД ---
gaps inner 12
gaps outer 6
default_border pixel 2
client.focused #cba6f7 #1e1e2e #cdd6f4 #cba6f7 #cba6f7

